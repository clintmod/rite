# Binaries for programs and plugins
*.exe
*.dll
*.so
*.dylib

# Test binary, build with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Graphvis files
*.gv

# Project-local glide cache, RE: https://github.com/Masterminds/glide/issues/736
.glide/

.rite/
# legacy cache name from pre-rename; ignore so coexistence testing is tidy
.task/
dist/

.DS_Store

# editors
.idea/
.vscode/
.fleet/
.claude/

# exuberant ctags
tags

/bin/*
!/bin/.keep
/tmp
node_modules
website/.netlify/

# pnpm is authoritative for the docs site; prevent stray `npm install`
# output from being committed
website/package-lock.json

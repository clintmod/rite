version: '3'

vars:
  GITHUB_TOKEN: from-include
  AWS_SECRET_ACCESS_KEY: also-a-secret

includes:
  core:
    taskfile: ./deep/core.Ritefile.yml

tasks:
  rotate:
    desc: Rotate secrets (task-scope shadow + secret var).
    vars:
      GITHUB_TOKEN: task-scope-override
    cmds:
      - echo "${GITHUB_TOKEN}"
